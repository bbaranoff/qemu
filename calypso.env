# --- capture ---
CALYPSO_CANNED=                 # vide = vrai SI grgsm
CALYPSO_IRDA_CAPTURE=0

# --- osmo-trx (Transceiver.cpp) ---
CALYPSO_START_FN=              # [REQUIS] horloge osmo-trx d  terministe -> osmo_trx_fn == internal_fn
CALYPSO_NB_MAXDLY=1            # [REQUIS >0] fen  tre TOA burst normal (sinon SDCCH/SABM jamais d  tect  )

# --- uplink RACH / FN ---
CALYPSO_UL_DEBUG=
CALYPSO_UL_SLOT_OFFSET=1875     # [tune] TOA intra-slot du RACH (LU RACH-DET toa~4.6 = bon)
CALYPSO_UL_RA=                  # vide = RA auto
CALYPSO_UL_FN_GATE=0            # [REQUIS] RACH inject   seulement sur slot   ligible
CALYPSO_UL_FN_OFFSET=36         # [REQUIS] pour le bloc SDCCH (coupl      eff_ofs=15 : 36+15=51 ^i 0 -> gate ~internal_fn).
                               #   NB : le gate RACH ignore d  sormais cet offset (corrig   : il gate sur internal_fn).
CALYPSO_UL_RACH_STICKY=8       # [tune MT-SMS] nb de slots RACH-  ligibles o   la paging-response (encod  e 1 ^w)
                               #   est r  -inject  e depuis g_rach_iq. Monter (16) si la 2e RACH-DET manque encore.

# --- IMM ASSIGN req-ref (FN-fix) ---
CALYPSO_REQREF_ADJ=            # [REQUIS] req-ref = FN exact du RACH_CONF (ADJ!=0 -> mismatch). (rewrite    retirer via unif L1)

# --- SDCCH UL (SABM) ---
# CALYPSO_UL_SDCCH_OFS  : NON d  fini -> eff_ofs=15 (offset d  terministe ; Q pinn   via ts_initial snap 102*5000).
CALYPSO_UL_SABM_HOLD_TTL=2     # [REQUIS] hold court : SABM d  cod  e puis IDLE -> laisse passer le L3 (30 = flood)

# --- shunt IQ grgsm + record ---
CALYPSO_SHUNT_IQ_CFILE=/dev/shm/dsp_iq.cfile
CALYPSO_RECORD_FILE=/dev/shm/record.cfile

# NB run-variance r  siduel (MT SMS "marche une fois") : le mobile doit   tre CAMP ^i quand le paging
# arrive. L'horloge L1 du mobile (seed SCH gr-gsm) est encore l'horloge NON unifi  e -> camping pas
# 100% stable run-  -run. Le fix propre = unifier la L1 sur internal_fn (== osmo-trx) -> stabilise le
# camping ET retire le req-ref rewrite. C'est la prochaine   tape.
