# calypso.env -- propre (2026-06-09). Pipeline qui s'enregistre (LU Accept) + reçoit un MT SMS.
# [REQUIS] = couplé au code/fix, NE PAS retirer.  [tune] = ajustable.

# --- capture ---
CALYPSO_CANNED=                 # vide = vrai SI grgsm
CALYPSO_IRDA_CAPTURE=0

# --- osmo-trx (Transceiver.cpp) ---
CALYPSO_START_FN=0              # [REQUIS] horloge osmo-trx déterministe -> osmo_trx_fn == internal_fn
CALYPSO_NB_MAXDLY=40            # [REQUIS >0] fenêtre TOA burst normal (sinon SDCCH/SABM jamais détecté)

# --- uplink RACH / FN ---
CALYPSO_UL_DEBUG=1
CALYPSO_UL_SLOT_OFFSET=1875     # [tune] TOA intra-slot du RACH (LU RACH-DET toa~4.6 = bon)
CALYPSO_UL_RA=                  # vide = RA auto
CALYPSO_UL_FN_GATE=1            # [REQUIS] RACH injecté seulement sur slot éligible
CALYPSO_UL_FN_OFFSET=36         # [REQUIS] pour le bloc SDCCH (couplé à eff_ofs=15 : 36+15=51≡0 -> gate ~internal_fn).
                               #   NB : le gate RACH ignore désormais cet offset (corrigé : il gate sur internal_fn).
CALYPSO_UL_RACH_STICKY=8       # [tune MT-SMS] nb de slots RACH-éligibles où la paging-response (encodée 1×)
                               #   est ré-injectée depuis g_rach_iq. Monter (16) si la 2e RACH-DET manque encore.

# --- IMM ASSIGN req-ref (FN-fix) ---
CALYPSO_REQREF_ADJ=0            # [REQUIS] req-ref = FN exact du RACH_CONF (ADJ!=0 -> mismatch). (rewrite à retirer via unif L1)

# --- SDCCH UL (SABM) ---
# CALYPSO_UL_SDCCH_OFS  : NON défini -> eff_ofs=15 (offset déterministe ; Q pinné via ts_initial snap 102*5000).
CALYPSO_UL_SABM_HOLD_TTL=2     # [REQUIS] hold court : SABM décodée puis IDLE -> laisse passer le L3 (30 = flood)

# --- shunt IQ grgsm + record ---
CALYPSO_SHUNT_IQ_CFILE=/dev/shm/dsp_iq.cfile
CALYPSO_RECORD_FILE=/dev/shm/record.cfile

# NB run-variance résiduel (MT SMS "marche une fois") : le mobile doit être CAMPÉ quand le paging
# arrive. L'horloge L1 du mobile (seed SCH gr-gsm) est encore l'horloge NON unifiée -> camping pas
# 100% stable run-à-run. Le fix propre = unifier la L1 sur internal_fn (== osmo-trx) -> stabilise le
# camping ET retire le req-ref rewrite. C'est la prochaine étape.
